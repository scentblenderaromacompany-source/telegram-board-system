# Telegram Board System - Environment Configuration
# Copy to .env and fill in your values

# ──────────────────────────────────────────────
# Telegram Bot Tokens (required for each bot)
# ──────────────────────────────────────────────
TBS_BOT_TOKEN_OPENCLAW=
TBS_BOT_TOKEN_HERMES=
TBS_BOT_TOKEN_CASPERS=
TBS_BOT_TOKEN_CONTENT=

# ──────────────────────────────────────────────
# Webhook Configuration (optional, for production)
# ──────────────────────────────────────────────
TBS_WEBHOOK_URL=
TBS_WEBHOOK_SECRET=

# ──────────────────────────────────────────────
# Business IDs
# ──────────────────────────────────────────────
TBS_BUSINESS_OPENCLAW=openclaw
TBS_BUSINESS_HERMES=hermes
TBS_BUSINESS_CASPERS=caspers_heritage
TBS_BUSINESS_CONTENT=content_business

# ──────────────────────────────────────────────
# Agent Configuration
# ──────────────────────────────────────────────
TBS_AGENT_MODEL=gpt-4
TBS_AGENT_TEMPERATURE=0.7
TBS_AGENT_MAX_CONTEXT=8192

# ──────────────────────────────────────────────
# Memory / Persistence
# ──────────────────────────────────────────────
TBS_MEMORY_DIR=config
TBS_MEMORY_MAX_ENTRIES=10000

# ──────────────────────────────────────────────
# Rate Limiting
# ──────────────────────────────────────────────
TBS_RATE_LIMIT_PER_SECOND=30
TBS_RATE_LIMIT_PER_CHAT=30

# ──────────────────────────────────────────────
# Security
# ──────────────────────────────────────────────
TBS_SECURITY_CONFIG=config/security.json

# ──────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────
TBS_LOG_LEVEL=INFO
TBS_LOG_DIR=logs
TBS_LOG_JSON=false

# ──────────────────────────────────────────────
# Proxy (optional)
# ──────────────────────────────────────────────
TBS_PROXY_URL=

# ──────────────────────────────────────────────
# Database (optional, for jewelry plugin)
# ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ──────────────────────────────────────────────
# Marketplace (optional, for jewelry plugin)
# ──────────────────────────────────────────────
EBAY_ENABLED=false
SHOPIFY_ENABLED=false
